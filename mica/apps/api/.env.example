NODE_ENV=development
PORT=4000

# Local dev Postgres (user-owned instance, see scripts/dev-infra-start.ps1 — NOT the system-wide Postgres service)
DATABASE_URL="postgresql://postgres:micamab_dev_pw@127.0.0.1:5434/mica_mab_dev?schema=public"

# Local dev Redis (portable, no-service instance, see scripts/dev-infra-start.ps1)
REDIS_URL="redis://127.0.0.1:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# Storage (local disk by default; abstraction supports swapping in S3 later)
STORAGE_DRIVER="local"
STORAGE_LOCAL_ROOT="./storage"
# S3 (only used when STORAGE_DRIVER=s3)
STORAGE_S3_BUCKET=""
STORAGE_S3_REGION=""
STORAGE_S3_ACCESS_KEY_ID=""
STORAGE_S3_SECRET_ACCESS_KEY=""
STORAGE_S3_ENDPOINT=""

# SMTP (dev: point at Maildev/Mailhog once running; production: real SMTP creds via Settings)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="MICA MAB Fleet <no-reply@mica-mab.local>"

# Encrypts secrets stored in the Setting table (currently the SMTP password),
# so they are not readable in a database dump or backup. At least 32 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Leaving it blank keeps the previous behaviour — the secret is stored in the
# clear and a warning is logged. Losing this key after secrets are encrypted
# makes them unreadable; back it up with your other credentials.
SETTINGS_ENCRYPTION_KEY=""

CORS_ORIGIN="http://localhost:3001"

# Directory containing pg_dump/pg_restore for the Backup module. Leave blank
# if they're already on PATH (typical in Docker/Linux deploys).
PG_BIN_DIR=""
