# Database (used by both `db` and `server` services)
DB_NAME=mab_united_db
DB_PASSWORD=ChangeMe_Strong_Password_2026!

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=replace_me_with_64_byte_hex_string

# Public URLs
FRONTEND_URL=https://yourdomain.com
PUBLIC_API_URL=https://yourdomain.com
CLIENT_PORT=80

# Email (Gmail App Password)
MAIL_FROM=your-email@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM_NAME=MAP UNITED IT

# Bootstrap: required to call POST /api/auth/register (creates first company).
# Leave empty in production after initial setup.
SETUP_KEY=
