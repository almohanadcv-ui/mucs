PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=mab_united_db
DB_DIALECT=mysql

# Connection pool — increase for higher concurrency (VPS DBs usually allow 100+)
DB_POOL_MAX=20
DB_POOL_MIN=2

# JWT Settings (use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
JWT_EXPIRES_IN=1d

# Upload Settings (5MB)
MAX_FILE_SIZE=5242880

# Bcrypt salt rounds
BCRYPT_SALT_ROUNDS=12

# Email Settings (Gmail App Password)
MAIL_FROM=
MAIL_PASS=
MAIL_FROM_NAME=MAP UNITED IT
