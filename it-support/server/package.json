  "license": "UNLICENSED",
  "private": true,
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "start:win": "set NODE_ENV=production&& node server.js",
    "dev": "nodemon server.js",
    "backup": "node scripts/backup.js",
    "backup:rotate": "node scripts/backup.js --rotate",
    "test:email": "node scripts/test-email.js",
    "migrate": "node scripts/migrate-add-plain-password.js",
    "migrate:soft-delete": "node scripts/migrate-ticket-soft-delete.js",
    "seed": "node seed.js",
    "reset-db": "node reset-db.js",
    "audit": "npm audit --production",
    "lint:check": "node -e \"console.log('No linter configured for server')\""
