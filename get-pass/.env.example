# انسخ هذا الملف إلى .env وعدّل القيم (في الإنتاج اضبطها كمتغيّرات بيئة على Railway)
PORT=4000
NODE_ENV=development

# مفتاح توقيع رموز JWT — إلزامي تغييره في الإنتاج إلى قيمة عشوائية طويلة جداً
# توليد مفتاح: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-very-long-random-secret-string
JWT_EXPIRES_IN=8h

# مجلد التخزين الدائم (قاعدة البيانات + المرفقات). في الإنتاج اضبطه على مسار القرص الدائم (Volume)، مثل: /data
DATA_DIR=

# مدة صلاحية التصريح الافتراضية بالأيام
DEFAULT_PERMIT_DAYS=365

# نافذة التجديد: يُسمح بطلب جديد خلال آخر (N) أيام قبل انتهاء التصريح
RENEWAL_WINDOW_DAYS=5

# الحد الأقصى لحجم الملف المرفوع (بايت) - 10MB
MAX_UPLOAD_BYTES=10485760

# نوع التحقق من الهوية: saudi | generic
NATIONAL_ID_MODE=saudi

# (اختياري) بيانات حساب الدعم الافتراضي عند الزرع الأول في الإنتاج
SEED_SUPPORT_EMAIL=
SEED_SUPPORT_PASSWORD=
