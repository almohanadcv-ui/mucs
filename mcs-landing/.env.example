# =====================================================================
# MCS — MAB United Control System (landing gateway)
#
# Optional per-environment overrides for each system's "Enter System" URL.
# If a variable is unset, the default in src/config/systems.ts is used.
# These are PUBLIC values (baked into the client) — never put secrets here.
#
# System → source folder mapping:
#   IT Support  → ../IT SUPPORT
#   GET PASS    → ../GET PASS
#   MICA        → ../MICA
#   Evaluation  → ../evaluation
# =====================================================================

NEXT_PUBLIC_SUPPORT_URL=https://support.mucs.online
NEXT_PUBLIC_GETPASS_URL=https://getpass.mucs.online
NEXT_PUBLIC_MICA_URL=https://mica.mucs.online
NEXT_PUBLIC_EVALUATION_URL=https://evaluation.mucs.online
